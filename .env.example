APP_ENV=development
QUIET_MODE=true

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://postgres:change-this-password@postgres:5432/maria_agent

# Vector store / Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
VECTOR_COLLECTION_NAME=maria_rag_collection

# Source tables used by the indexing pipeline
SOURCE_TABLES=product_catalog,sales,employees,absenteeism_events,purchase_orders,inventory_movements,daily_stock_snapshot,customer_orders,sales_targets,supplier_deliveries,product_price_history
INDEX_BATCH_SIZE=100
AUTO_REINDEX_ON_EMPTY_INDEX=true

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# Retrieval
SEARCH_K=4
SEARCH_FETCH_K=12
MIN_RETRIEVED_DOCUMENTS=1
MAX_CONTEXT_CHARS=6000
REQUIRE_SOURCE_ATTRIBUTION=true
FALLBACK_IF_NO_CONTEXT=true

# Agent tools
ENABLE_VECTOR_TOOL=true
ENABLE_SQL_TOOL=true
MAX_TOOL_CALLS=6

# Conversation memory
ENABLE_CONVERSATION_MEMORY=true
ENABLE_USER_MEMORY=true
MEMORY_RECENT_MESSAGES=6
MEMORY_SUMMARIZE_AFTER_MESSAGES=8
MEMORY_SUMMARY_MAX_CHARS=1800
USER_MEMORY_TOP_K=3

# Input guardrails
MIN_QUESTION_CHARS=5
MAX_QUESTION_CHARS=500
BLOCKED_INPUT_PATTERNS=(?i)ignore previous instructions||(?i)drop table||(?i)delete from||(?i)shutdown

# SQL guardrails
ALLOW_ONLY_SELECT_SQL=true
SQL_MAX_ROWS=20

# Output guardrails
MASK_EMAILS=true
MASK_PHONES=true
MASK_CPFS=true

# API
API_HOST=0.0.0.0
API_PORT=8000
WEB_HOST=0.0.0.0
WEB_PORT=8501
WEB_USER_ID=web-user

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0
OPENAI_API_KEY=

# Langfuse observability
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# MinIO rules repository
MINIO_ENABLED=true
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=mariaagent
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_SECURE=false
MINIO_RULES_BUCKET=maria-rules
MINIO_RULES_PREFIX=rules/
MINIO_RULES_EXTENSIONS=.md,.txt
MINIO_RULES_MAX_BYTES=262144
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# Embeddings
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

# Optional local model provider
OLLAMA_BASE_URL=http://localhost:11434

# Evolution Go / WhatsApp
EVOLUTION_ENABLED=true
EVOLUTION_BASE_URL=http://evolution-go:8080
EVOLUTION_API_KEY=change-this-key
EVOLUTION_INTERNAL_WEBHOOK_URL=http://app:8000/webhooks/evolution
EVOLUTION_INSTANCE_NAME=maria-whatsapp
EVOLUTION_INSTANCE_ID=
EVOLUTION_SUBSCRIBE_EVENTS=MESSAGE,CONNECTION,QRCODE
EVOLUTION_WEBHOOK_SECRET=
EVOLUTION_PUBLIC_WEBHOOK_URL=
EVOLUTION_DEFAULT_STORE_ID=
EVOLUTION_IGNORE_GROUP_MESSAGES=true
EVOLUTION_IGNORE_NEWSLETTER_MESSAGES=true
EVOLUTION_REPLY_TO_MEDIA_WITHOUT_TEXT=false
EVOLUTION_UNAUTHORIZED_NUMBER_MESSAGE=Seu numero nao esta autorizado para usar este atendimento. Fale com o responsavel pela operacao para solicitar liberacao.

# Traefik
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com
TRAEFIK_APP_HOST=maria.example.com
TRAEFIK_WEB_HOST=chat.maria.example.com
TRAEFIK_EVOLUTION_HOST=evolution.example.com
TRAEFIK_MINIO_HOST=minio.maria.example.com
TRAEFIK_GRAFANA_HOST=grafana.maria.example.com
TRAEFIK_PROMETHEUS_HOST=prometheus.maria.example.com
TRAEFIK_BASIC_AUTH_USERS=admin:$2b$12$vEmvWa0aRKdbWMVxqWVdmeJfU6ymAOADRQil2C0sD23Zq/gPbgL6i
GRAFANA_ADMIN_PASSWORD=admin
